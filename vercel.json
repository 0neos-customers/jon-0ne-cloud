{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build --filter=web",
  "installCommand": "bun install",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/podcast",
      "destination": "https://open.spotify.com/playlist/5xFAYhRQQaOnMPbmyq49lf",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/hand-raiser-check",
      "schedule": "*/15 * * * *"
    }
  ]
}
